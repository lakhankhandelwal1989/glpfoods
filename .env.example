# ────────────────────────────────────────────
# GLP — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these in the Variables tab.
# ────────────────────────────────────────────

# Provided automatically by Railway's PostgreSQL plugin
DATABASE_URL=postgres://user:password@host:5432/dbname

# Server port (Railway provides PORT automatically)
PORT=3000

# JWT signing secret — generate a long random string in production
# Example: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace-with-a-long-random-string-in-production

# Set to "production" on Railway
NODE_ENV=development
